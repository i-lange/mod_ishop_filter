{
  "name": "mod_ishop_filter",
  "version": "1.0.8",
  "author": {
    "name": "Pavel Lange",
    "email": "pavel@ilange.ru",
    "url": "https://ilange.ru"
  },
  "private": true,
  "type": "module",
  "license": "GPL-2.0-or-later",
  "description": "Product Filter Module for E-commerce Extension com_ishop for CMS Joomla! v6",
  "keywords": [
    "joomla",
    "joomla 6",
    "joomla-module",
    "ecommerce",
    "ishop",
    "mod_ishop_filter"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/i-lange/mod_ishop_filter.git"
  },
  "bugs": {
    "url": "https://github.com/i-lange/mod_ishop_filter/issues"
  },
  "browserslist": [
    "last 2 versions",
    "not dead",
    "> 0.5%"
  ],
  "main": "",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.8",
    "archiver": "^7.0.1",
    "happy-dom": "^20.10.2",
    "lightningcss": "^1.32.0",
    "sass": "^1.98.0",
    "vite": "8.0.5",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.8",
    "yauzl": "^3.4.0"
  },
  "scripts": {
    "build": "node build.mjs",
    "build:css": "vite build --config vite.config.css.mts",
    "build:js": "vite build --config vite.config.js.mts",
    "watch:css": "vite build --watch --config vite.config.css.mts",
    "watch:js": "vite build --watch --config vite.config.js.mts",
    "test": "pnpm test:php && pnpm test:js",
    "test:php": "node tests/tools/run-phpunit.mjs",
    "test:php:coverage": "node tests/tools/run-phpunit.mjs --coverage-clover build/coverage/php-clover.xml && node tests/tools/check-php-coverage.mjs",
    "test:js": "vitest run",
    "test:js:coverage": "vitest run --coverage",
    "test:coverage": "pnpm test:php:coverage && pnpm test:js:coverage",
    "test:all": "pnpm build && pnpm test && pnpm zip",
    "zip": "pnpm build && node pack.mjs"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.8.0",
    "pnpm": ">=10.3.0"
  }
}
