      "type": "script",
      "uri": "mod_ishop_filter/slider.js",
      "dependencies": ["core"],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "ishop_filter.front",
      "type": "script",
      "uri": "mod_ishop_filter/front.js",
      "dependencies": ["core", "ishop_filter.range"],
      "attributes": {
        "defer": true
      }
    }
  ]
